root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts,java}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{json,yml,yaml,toml,xml,html,css,scss,md,ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
